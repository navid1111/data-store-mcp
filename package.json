{
  "name": "data-store-mcp",
  "version": "0.1.0",
  "description": "data-store-mcp - MCP server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:golden": "node dist/evaluation/run.js",
    "fixtures": "./scripts/fetch-fixtures.sh",
    "db:up": "./scripts/fetch-fixtures.sh && docker compose up -d --wait --wait-timeout 600",
    "db:down": "docker compose down -v",
    "db:reset": "docker compose down -v && npm run db:up",
    "db:logs": "docker compose logs -f"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "server"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mongodb": "^6.20.0",
    "mssql": "^12.2.0",
    "mysql2": "^3.16.0",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.16.3",
    "yaml": "^2.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mssql": "^9.1.8",
    "@types/mysql": "^2.15.27",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.16.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
