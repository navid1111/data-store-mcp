{
  "name": "data-store-mcp",
  "displayName": "Data Store MCP",
  "description": "Governed, described database access for GitHub Copilot and other MCP agents",
  "version": "0.1.0",
  "publisher": "REPLACE_WITH_YOUR_PUBLISHER_ID",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/REPLACE/data-store-mcp" },
  "engines": {
    "//": "registerMcpServerDefinitionProvider became stable in 1.101. Do not lower this.",
    "vscode": "^1.101.0"
  },
  "categories": ["AI", "Data Science", "Other"],
  "keywords": ["mcp", "copilot", "database", "postgres", "mysql", "mongodb"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "dataStoreMcp.provider",
        "label": "Data Store MCP"
      }
    ],
    "commands": [
      {
        "command": "dataStoreMcp.initConfig",
        "title": "Data Store MCP: Create Config File",
        "category": "Data Store MCP"
      },
      {
        "command": "dataStoreMcp.openConfig",
        "title": "Data Store MCP: Open Config File",
        "category": "Data Store MCP"
      },
      {
        "command": "dataStoreMcp.checkSetup",
        "title": "Data Store MCP: Check Setup",
        "category": "Data Store MCP"
      },
      {
        "command": "dataStoreMcp.restart",
        "title": "Data Store MCP: Reload Server",
        "category": "Data Store MCP"
      }
    ],
    "configuration": {
      "title": "Data Store MCP",
      "properties": {
        "dataStoreMcp.configPath": {
          "type": "string",
          "default": "data-store-mcp.config.json",
          "markdownDescription": "Path to the config file, relative to the workspace root. See the [config guide](https://github.com/REPLACE/data-store-mcp/blob/main/EXTENSION.md#config-reference)."
        },
        "dataStoreMcp.envFile": {
          "type": "string",
          "default": ".env",
          "markdownDescription": "File supplying `${VARIABLE}` values used in the config. Relative to the workspace root. Never commit this file."
        },
        "dataStoreMcp.nodePath": {
          "type": "string",
          "default": "node",
          "description": "Node executable used to run the bundled server. Node 18+ required."
        },
        "dataStoreMcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Register the MCP server with Copilot. Turn off to disable without uninstalling."
        }
      }
    }
  },
  "scripts": {
    "build:server": "node scripts/bundle-server.mjs",
    "build:extension": "esbuild src/extension.ts --bundle --platform=node --target=node18 --format=cjs --external:vscode --outfile=dist/extension.js",
    "build": "npm run build:server && npm run build:extension",
    "watch": "npm run build:extension -- --watch",
    "package": "npm run build && vsce package",
    "publish": "npm run build && vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.3"
  }
}
