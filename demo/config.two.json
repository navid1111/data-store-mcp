{
  "principal": "analyst-two",
  "semantic": {
    "path": "./semantic"
  },
  "audit": {
    "path": "./demo/audit-two.jsonl"
  },
  "limits": {
    "maxResultBytes": 10485760,
    "timeoutMs": 30000
  },
  "sources": [
    {
      "name": "pagila",
      "type": "postgres",
      "description": "Pagila DVD-rental sample database",
      "options": {
        "host": "127.0.0.1",
        "port": 55432,
        "user": "postgres",
        "password": "dsm_test_pw",
        "database": "pagila"
      }
    },
    {
      "name": "sakila",
      "type": "mysql",
      "description": "Sakila DVD-rental sample database",
      "options": {
        "host": "127.0.0.1",
        "port": 53306,
        "user": "dsm",
        "password": "dsm_test_pw",
        "database": "sakila"
      }
    }
  ],
  "policies": {
    "roles": {
      "store-one": {
        "rowFilters": [
          {
            "name": "customer-store",
            "model": "customer",
            "column": "store_id",
            "operator": "eq",
            "value": 1
          }
        ],
        "hiddenColumns": [
          {
            "name": "hide-email",
            "model": "customer",
            "columns": [
              "email"
            ]
          }
        ]
      },
      "store-two": {
        "rowFilters": [
          {
            "name": "customer-store",
            "model": "customer",
            "column": "store_id",
            "operator": "eq",
            "value": 2
          }
        ]
      }
    },
    "principals": {
      "analyst-one": {
        "roles": [
          "store-one"
        ]
      },
      "analyst-two": {
        "roles": [
          "store-two"
        ]
      }
    }
  }
}
